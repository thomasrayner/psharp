# Find prime numbers
fn is_prime(n) {
    if n < 2 {
        return false
    }
    
    let i = 2
    while i * i <= n {
        if n % i == 0 {
            return false
        }
        i = i + 1
    }
    
    return true
}

# Print first 20 numbers and mark which are prime
for num in range(1, 20) {
    if is_prime(num) {
        print(num)
        print(" is prime")
    }
}
