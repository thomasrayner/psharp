# Math operations
let a = 10
let b = 3

print(a + b)    # 13
print(a - b)    # 7
print(a * b)    # 30
print(a / b)    # 3.333...
print(a % b)    # 1
print(a ** 2)   # 100

# Math functions
print(abs(-42))         # 42
print(sqrt(16))         # 4
print(floor(3.7))       # 3
print(ceil(3.2))        # 4
print(round(3.14159))   # 3
print(pow(2, 8))        # 256

# Array math
let nums = [10, 20, 5, 15, 8]
print(sum(nums))        # 58
print(min(nums))        # 5
print(max(nums))        # 20
